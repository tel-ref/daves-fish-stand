{
  "name": "davesfishstand",
  "main": "./worker.js",
  "compatibility_date": "2026-07-13",
  "compatibility_flags": ["nodejs_compat"],
  "routes": [
    { "pattern": "davesfishstand.com", "custom_domain": true },
    { "pattern": "www.davesfishstand.com", "custom_domain": true }
  ],
  "assets": {
    "directory": "./",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"]
  }
}
