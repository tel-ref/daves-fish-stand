{
  "name": "davesfishstand",
  "main": "./worker.js",
  "compatibility_date": "2026-07-13",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*", "/.well-known/apple-developer-merchantid-domain-association"]
  }
}
